.Filter {
    &_desc {
        color: var(--text-description-description-default);
    }

    &_link {
        cursor: pointer;
        text-decoration: underline;
    }

    &_homepage {
        padding-top: 4px;
    }

    &_warning {
        padding-top: 4px;
    }
}